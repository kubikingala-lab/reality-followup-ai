# Reality Follow-up AI - Standalone Configuration
# Copy this file to .env and fill in your values

# Application
NODE_ENV=development
PORT=3000

# Database (MySQL)
MYSQLHOST=db
MYSQLPORT=3306
MYSQLUSER=reality_user
MYSQLPASSWORD=your_secure_password_here
MYSQLDATABASE=reality_followup_ai
DATABASE_URL="mysql://reality_user:your_secure_password_here@db:3306/reality_followup_ai"

# Session & Security
JWT_SECRET=your_random_jwt_secret_here_min_32_chars

# AI API (for AI-generated responses)
# Prioritizes GEMINI_API_KEY if both are set.
GEMINI_API_KEY=your-google-gemini-api-key-here
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# Resend Email Service (for sending emails)
RESEND_API_KEY=re_your_resend_api_key_here

# Google Calendar Integration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback

# Scheduler
SCHEDULER_SECRET=your_scheduler_secret_here

# Application Branding
VITE_APP_TITLE=Reality Follow-up AI
VITE_APP_LOGO=/logo.png

# Note: The following are kept for backward compatibility but not used in standalone mode
VITE_APP_ID=standalone-app
VITE_OAUTH_PORTAL_URL=https://manus.im
OAUTH_SERVER_URL=https://api.manus.im
OWNER_OPEN_ID=standalone-owner
OWNER_NAME=Standalone User
BUILT_IN_FORGE_API_URL=https://forge.manus.im
BUILT_IN_FORGE_API_KEY=not-used-in-standalone
VITE_FRONTEND_FORGE_API_KEY=not-used-in-standalone
VITE_FRONTEND_FORGE_API_URL=https://forge.manus.im
